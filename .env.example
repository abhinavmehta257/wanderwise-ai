# Meta Graph API (Instagram / Messenger messaging)
META_GRAPH_API_VERSION=v21.0
# Optional override; omit to use META_GRAPH_API_VERSION
# META_MESSAGE_URL=https://graph.facebook.com/v21.0/me/messages

# Instagram webhook verification
INSTA_VERIFICATION_STRING=

# Meta page access token
OURBABYPICS_ACCESS_TOKEN=

# Langflow
LANF_FLOW_URL=
LANG_FLOW_ACCESS_TOKEN=

# Database
MONGODB_URI=

# OpenAI
OPEN_AI_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Internal API auth + form token signing
API_SECRET_KEY=

# Public site URL (form links, trip links)
NEXT_PUBLIC_BASE_URL=

# Unsplash (destination hero images)
UNSPLASH_ACCESS_KEY=
